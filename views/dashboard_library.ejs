<!DOCTYPE html>
<html class="dark" lang="en">
<%- include('partials/head', {title: 'SimplyOver | My Library'}) %>
<body class="overflow-x-hidden">
    <%- include('partials/navbar') %>
    <div class="flex min-h-[calc(100vh-80px)]">
        <%- include('partials/dashboard_sidebar', {activeTab: 'library'}) %>

        <!-- Main Content Canvas -->
        <main class="flex-1 md:ml-[280px] px-5 md:px-12 py-12">
            <!-- Header Section -->
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-8">
                <div>
                    <h1 class="text-5xl font-bold text-white mb-2">My Library</h1>
                    <p class="text-lg text-on-surface-variant max-w-xl">
                        Access all your purchased overlays, digital assets, and customized streaming kits. Ready for your next broadcast.
                    </p>
                </div>
                <div class="flex items-center gap-3">
                    <div class="glass-level-1 flex items-center px-4 py-2.5 rounded-full">
                        <span class="material-symbols-outlined text-secondary mr-2">search</span>
                        <input class="bg-transparent border-none focus:ring-0 text-sm font-semibold w-48 placeholder:text-on-surface-variant/50 text-white" placeholder="Search my assets..." type="text"/>
                    </div>
                    <button class="glass-level-2 p-2.5 rounded-full text-on-surface-variant hover:text-white transition-colors">
                        <span class="material-symbols-outlined">sort</span>
                    </button>
                </div>
            </div>

            <!-- Library Content Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                <!-- Card 1 -->
                <div class="glass-level-1 rounded-2xl overflow-hidden group hover:border-primary/50 transition-all duration-300 flex flex-col">
                    <div class="relative overflow-hidden aspect-[16/10]">
                        <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCX5RjR0aF1A73qywyyEEkHi8zVCi0uVD5fck459lpAc4HIjdAB0SffrBZWUT0Hkd1DjsJCe-Bg3H3llEwV02U9qmCqEQatNAuvdvwwgcTGpFP2XLjwN5EawCTVD0J9i9OQM9Oy7QG6Zq3sBZUUTjPHF_VitFxOpOn8SbLb949-GFG4QyQUWFZf3OpRDZhf-QFzGIskYpy1eNtYA5XqVopYVKah76Kq1JGlvLvjaVJuXY_ACeiH0NXKB1es9272rrSBY4oTudbzmFU"/>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
                            <span class="text-white text-xs font-semibold bg-primary/20 backdrop-blur-md px-2 py-1 rounded">V2.4 Updated</span>
                        </div>
                    </div>
                    <div class="p-5 flex-1 flex flex-col">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <h3 class="text-lg font-semibold text-white mb-1">Cyber Drifter Kit</h3>
                                <p class="text-on-surface-variant text-xs">By StudioX</p>
                            </div>
                        </div>
                        <div class="mt-auto flex items-center justify-between gap-3 pt-4 border-t border-white/5">
                            <button class="flex-1 py-2 rounded-lg bg-secondary/10 text-secondary font-semibold hover:bg-secondary/20 transition-colors flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">download</span> Download
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Card 2 -->
                <div class="glass-level-1 rounded-2xl overflow-hidden group hover:border-primary/50 transition-all duration-300 flex flex-col">
                    <div class="relative overflow-hidden aspect-[4/3]">
                        <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCBVGeklX__73K5trHvCFGWVoVBPcU3CiddLL4itB4g5a9zd-GqaQNgn3NboEvnlz4TvNdSEb8_BUHkK2z30WI7Mu8ejY7YpIFs1mAHCLSK6iaQry1DzLOjjFzpFNaQ74MhOBqqbBzMK04V7a8gmZHntM6w7-VXzMr2plBFQbtubBvi5lxEp2yb4EnSTprM7o-zTG4q-WGrCS4c_12VftHtu2e7x_Ybj1dj1ba1mCzHLNP9F0TaBKdoLyfCI44Xaw2Lp3xHfsa23Wo"/>
                    </div>
                    <div class="p-5 flex-1 flex flex-col">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <h3 class="text-lg font-semibold text-white mb-1">Zen Garden Stream</h3>
                                <p class="text-on-surface-variant text-xs">By MochiDesign</p>
                            </div>
                        </div>
                        <div class="mt-auto flex items-center justify-between gap-3 pt-4 border-t border-white/5">
                            <button class="flex-1 py-2 rounded-lg bg-secondary/10 text-secondary font-semibold hover:bg-secondary/20 transition-colors flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">download</span> Download
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Empty State / Load More -->
            <div class="mt-16 flex flex-col items-center justify-center py-12 border-2 border-dashed border-white/5 rounded-3xl">
                <div class="w-16 h-16 bg-white/5 rounded-full flex items-center justify-center mb-4">
                    <span class="material-symbols-outlined text-on-surface-variant text-4xl">auto_awesome</span>
                </div>
                <h3 class="text-2xl font-bold text-white mb-2">Find more assets</h3>
                <p class="text-on-surface-variant mb-6">Explore thousands of premium OBS overlays and stream packs.</p>
                <a href="/" class="glass-level-1 px-8 py-3 rounded-full text-primary font-semibold hover:bg-white/10 transition-all">Go to Marketplace</a>
            </div>
        </main>
    </div>
</body>
</html>
