<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>SimplyOver | My Library</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "primary": "#d2bbff",
                        "secondary": "#4cd7f6",
                        "tertiary": "#ddb7ff",
                        "background": "#13131a",
                        "on-background": "#e4e1ec",
                        "surface": "#13131a",
                        "on-surface": "#e4e1ec",
                        "surface-container": "#1f1f26",
                        "primary-container": "#7c3aed",
                        "secondary-container": "#03b5d3",
                        "on-surface-variant": "#ccc3d8",
                        "surface-container-highest": "#34343c"
                    },
                    "fontFamily": {
                        "headline-xl": ["Inter"],
                        "headline-md": ["Inter"],
                        "body-md": ["Inter"],
                        "label-md": ["Inter"],
                        "body-lg": ["Inter"],
                        "label-sm": ["Inter"]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-level-1 {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        .glass-level-2 {
            background: rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(18px);
            border: 1px solid rgba(255, 255, 255, 0.12);
        }
        .primary-gradient {
            background: linear-gradient(45deg, #7c3aed, #ddb7ff);
        }
        body {
            background-color: #0D0D14;
            color: #e4e1ec;
            font-family: 'Inter', sans-serif;
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.02);
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 2px;
        }
    </style>
</head>
<body class="overflow-x-hidden">
    <!-- TopNavBar (Large) -->
    <nav class="sticky top-0 w-full z-50 bg-surface/30 backdrop-blur-md border-b border-white/10 shadow-sm flex items-center justify-between px-6 h-20">
        <div class="flex items-center gap-8">
            <a href="/" class="text-2xl font-bold text-primary">SimplyOver</a>
            <div class="hidden md:flex items-center gap-6">
                <a class="text-on-surface-variant font-semibold hover:bg-white/5 transition-colors px-3 py-1 rounded-lg" href="/">All</a>
                <a class="text-on-surface-variant font-semibold hover:bg-white/5 transition-colors px-3 py-1 rounded-lg" href="#">Anime</a>
                <a class="text-on-surface-variant font-semibold hover:bg-white/5 transition-colors px-3 py-1 rounded-lg" href="#">Esports</a>
                <a class="text-on-surface-variant font-semibold hover:bg-white/5 transition-colors px-3 py-1 rounded-lg" href="#">Neon</a>
            </div>
        </div>
        <div class="flex items-center gap-4">
            <a href="/login" class="hidden sm:block text-on-surface-variant font-semibold px-4 py-2 hover:bg-white/5 transition-colors rounded-lg">Login</a>
            <a href="/dashboard/library" class="primary-gradient text-white font-semibold px-6 py-2.5 rounded-full shadow-lg shadow-primary-container/20 active:scale-95 transition-all">Start Creating</a>
        </div>
    </nav>
    <div class="flex min-h-[calc(100vh-80px)]">
        <!-- SideNavBar (Left) -->
        <aside class="fixed left-0 h-full w-[280px] bg-surface-container/40 backdrop-blur-xl border-r border-white/10 flex flex-col py-8 z-40 hidden md:flex">
            <div class="px-8 mb-10">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-12 h-12 rounded-full border-2 border-primary overflow-hidden">
                        <img alt="Avatar" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBeOc3lzebNG534uqNyyuebhVk4d4lpx8KgQbJxIHh0SQoqPjzHbYNNp54XddEIjtDjQhsBPs1LbIYJ7g5n3Ethfd77x8igz1aCS_tG4VwTv288cOj5DQ5Y-roJLqNiRGZD9LZWF4tA2rKH3zFMP_LI8MzH9A92O_5RoMTfLlAXu26aHoV8C_mx8rX-VAD1aMlqQDw8ygIjQiNSbjWz4RphaEg3_5v_Rj8zWirP6h7waIrfDX21pxtZvhPyrdc9eZi1ziOQ-JCLoOw"/>
                    </div>
                    <div>
                        <p class="font-semibold text-white">NeonOver</p>
                        <p class="text-xs text-on-surface-variant">Pro Designer</p>
                    </div>
                </div>
                <h2 class="text-2xl font-bold text-primary mb-1">My Dashboard</h2>
            </div>
            <nav class="flex-1 space-y-1">
                <a class="flex items-center gap-4 px-8 py-4 border-l-4 border-primary bg-primary/10 text-primary transition-all duration-300" href="/dashboard/library">
                    <span class="material-symbols-outlined">library_music</span>
                    <span class="font-semibold">My Library</span>
                </a>
                <a class="flex items-center gap-4 px-8 py-4 text-on-surface-variant hover:bg-white/5 transition-all duration-300" href="/dashboard/boards">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span class="font-semibold">My Boards</span>
                </a>
            </nav>
        </aside>

        <!-- Main Content Canvas -->
        <main class="flex-1 md:ml-[280px] px-5 md:px-12 py-12">
            <!-- Header Section -->
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-8">
                <div>
                    <h1 class="text-5xl font-bold text-white mb-2">My Library</h1>
                    <p class="text-lg text-on-surface-variant max-w-xl">
                        Access all your purchased overlays, digital assets, and customized streaming kits. Ready for your next broadcast.
                    </p>
                </div>
                <div class="flex items-center gap-3">
                    <div class="glass-level-1 flex items-center px-4 py-2.5 rounded-full">
                        <span class="material-symbols-outlined text-secondary mr-2">search</span>
                        <input class="bg-transparent border-none focus:ring-0 text-sm font-semibold w-48 placeholder:text-on-surface-variant/50 text-white" placeholder="Search my assets..." type="text"/>
                    </div>
                    <button class="glass-level-2 p-2.5 rounded-full text-on-surface-variant hover:text-white transition-colors">
                        <span class="material-symbols-outlined">sort</span>
                    </button>
                </div>
            </div>

            <!-- Library Content Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                <!-- Card 1 -->
                <div class="glass-level-1 rounded-2xl overflow-hidden group hover:border-primary/50 transition-all duration-300 flex flex-col">
                    <div class="relative overflow-hidden aspect-[16/10]">
                        <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCX5RjR0aF1A73qywyyEEkHi8zVCi0uVD5fck459lpAc4HIjdAB0SffrBZWUT0Hkd1DjsJCe-Bg3H3llEwV02U9qmCqEQatNAuvdvwwgcTGpFP2XLjwN5EawCTVD0J9i9OQM9Oy7QG6Zq3sBZUUTjPHF_VitFxOpOn8SbLb949-GFG4QyQUWFZf3OpRDZhf-QFzGIskYpy1eNtYA5XqVopYVKah76Kq1JGlvLvjaVJuXY_ACeiH0NXKB1es9272rrSBY4oTudbzmFU"/>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
                            <span class="text-white text-xs font-semibold bg-primary/20 backdrop-blur-md px-2 py-1 rounded">V2.4 Updated</span>
                        </div>
                    </div>
                    <div class="p-5 flex-1 flex flex-col">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <h3 class="text-lg font-semibold text-white mb-1">Cyber Drifter Kit</h3>
                                <p class="text-on-surface-variant text-xs">By StudioX</p>
                            </div>
                        </div>
                        <div class="mt-auto flex items-center justify-between gap-3 pt-4 border-t border-white/5">
                            <button class="flex-1 py-2 rounded-lg bg-secondary/10 text-secondary font-semibold hover:bg-secondary/20 transition-colors flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">download</span> Download
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Card 2 -->
                <div class="glass-level-1 rounded-2xl overflow-hidden group hover:border-primary/50 transition-all duration-300 flex flex-col">
                    <div class="relative overflow-hidden aspect-[4/3]">
                        <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCBVGeklX__73K5trHvCFGWVoVBPcU3CiddLL4itB4g5a9zd-GqaQNgn3NboEvnlz4TvNdSEb8_BUHkK2z30WI7Mu8ejY7YpIFs1mAHCLSK6iaQry1DzLOjjFzpFNaQ74MhOBqqbBzMK04V7a8gmZHntM6w7-VXzMr2plBFQbtubBvi5lxEp2yb4EnSTprM7o-zTG4q-WGrCS4c_12VftHtu2e7x_Ybj1dj1ba1mCzHLNP9F0TaBKdoLyfCI44Xaw2Lp3xHfsa23Wo"/>
                    </div>
                    <div class="p-5 flex-1 flex flex-col">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <h3 class="text-lg font-semibold text-white mb-1">Zen Garden Stream</h3>
                                <p class="text-on-surface-variant text-xs">By MochiDesign</p>
                            </div>
                        </div>
                        <div class="mt-auto flex items-center justify-between gap-3 pt-4 border-t border-white/5">
                            <button class="flex-1 py-2 rounded-lg bg-secondary/10 text-secondary font-semibold hover:bg-secondary/20 transition-colors flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-[18px]">download</span> Download
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Empty State / Load More -->
            <div class="mt-16 flex flex-col items-center justify-center py-12 border-2 border-dashed border-white/5 rounded-3xl">
                <div class="w-16 h-16 bg-white/5 rounded-full flex items-center justify-center mb-4">
                    <span class="material-symbols-outlined text-on-surface-variant text-4xl">auto_awesome</span>
                </div>
                <h3 class="text-2xl font-bold text-white mb-2">Find more assets</h3>
                <p class="text-on-surface-variant mb-6">Explore thousands of premium OBS overlays and stream packs.</p>
                <a href="/" class="glass-level-1 px-8 py-3 rounded-full text-primary font-semibold hover:bg-white/10 transition-all">Go to Marketplace</a>
            </div>
        </main>
    </div>
</body>
</html>
