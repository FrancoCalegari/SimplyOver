        .glass-surface-hover:hover {
            background: rgba(255, 255, 255, 0.06);
            backdrop-filter: blur(18px);
        }
        .masonry-grid {
            column-count: 2;
            column-gap: 16px;
        }
        @media (min-width: 1024px) {
            .masonry-grid {
                column-count: 4;
                column-gap: 24px;
            }
        }
        @media (min-width: 1536px) {
