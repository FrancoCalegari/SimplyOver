                        <span class="text-[10px] font-bold text-secondary uppercase tracking-tighter">Alert Zone</span>
                        <div class="absolute -top-1 -left-1 w-2 h-2 bg-secondary rounded-full"></div>
                    </div>
                    <div class="absolute bottom-4 right-4 w-64 h-36 border border-secondary border-dashed flex items-center justify-center cyan-glow bg-secondary/5 canvas-item cursor-pointer">
                        <span class="text-[10px] font-bold text-secondary uppercase tracking-tighter">Webcam Frame</span>
                    </div>
                    <div class="absolute bottom-4 left-4 w-56 h-64 border border-secondary border-dashed flex items-center justify-center cyan-glow bg-secondary/5 canvas-item cursor-pointer">
                        <span class="text-[10px] font-bold text-secondary uppercase tracking-tighter">Chat Box</span>
                    </div>
                    <!-- Decorative UI items -->
                    <div class="absolute top-0 right-0 w-32 h-1 bg-gradient-to-l from-primary to-transparent pointer-events-none"></div>
                    <div class="absolute bottom-0 left-0 w-1 h-32 bg-gradient-to-t from-primary to-transparent pointer-events-none"></div>
                </div>
            </div>
            
            <!-- Floating Bottom Tools -->
            <div class="absolute bottom-28 left-1/2 -translate-x-1/2 flex items-center gap-4 p-2 glass-panel rounded-2xl z-20">
