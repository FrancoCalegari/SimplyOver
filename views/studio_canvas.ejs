            <!-- Tabs -->
            <div class="flex border-b border-outline-variant">
                <button class="flex-1 py-3 text-xs font-bold text-primary border-b-2 border-primary">Canvas</button>
                <button class="flex-1 py-3 text-xs font-bold text-on-surface-variant hover:text-on-surface transition-colors">Layers</button>
                <button class="flex-1 py-3 text-xs font-bold text-on-surface-variant hover:text-on-surface transition-colors">Assets</button>
            </div>
            
            <div class="flex-1 overflow-y-auto p-4 space-y-6">
                <!-- Canvas Section -->
                <section class="space-y-4">
                    <div>
                        <label class="text-[10px] font-bold text-on-surface-variant uppercase mb-2 block">Resolution</label>
