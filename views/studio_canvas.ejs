                <button class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-surface-variant/40 text-on-surface-variant"><span class="material-symbols-outlined text-[20px]">text_fields</span></button>
                <button class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-surface-variant/40 text-on-surface-variant"><span class="material-symbols-outlined text-[20px]">image</span></button>
                <div class="w-px h-4 bg-outline-variant mx-1"></div>
                <button class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-surface-variant/40 text-on-surface-variant"><span class="material-symbols-outlined text-[20px]">brush</span></button>
            </div>
            
            <!-- Canvas Container -->
            <div class="flex-1 flex items-center justify-center p-12 overflow-auto">
