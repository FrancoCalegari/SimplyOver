                            <input class="flex-1 bg-surface-container-high border-outline-variant rounded-lg text-xs" type="text" value="#000000"/>
                            <div class="w-8 h-8 rounded-lg bg-surface-variant/20 border border-outline-variant flex items-center justify-center">
                                <span class="material-symbols-outlined text-sm">opacity</span>
                            </div>
                        </div>
                    </div>
                    <div>
                        <label class="text-[10px] font-bold text-on-surface-variant uppercase mb-2 block">Export Quality</label>
                        <div class="grid grid-cols-2 gap-2">
                            <div class="p-3 glass-panel border-primary bg-primary/5 rounded-xl text-center cursor-pointer">
                                <p class="text-xs font-bold text-primary">WebM</p>
                                <p class="text-[9px] text-on-surface-variant">Transparent</p>
                            </div>
                            <div class="p-3 glass-panel rounded-xl text-center cursor-pointer hover:bg-surface-variant/20">
                                <p class="text-xs font-bold">MOV</p>
                                <p class="text-[9px] text-on-surface-variant">Lossless</p>
                            </div>
                        </div>
                    </div>
                </section>
                
                <div class="h-px bg-outline-variant"></div>
                
                <!-- Layers Section -->
                <section class="space-y-2">
                    <label class="text-[10px] font-bold text-on-surface-variant uppercase mb-3 block">Scene Layers</label>
                    <div class="space-y-1">
                        <div class="flex items-center justify-between p-2 rounded-lg bg-primary-container/10 border border-primary/20">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-xs text-secondary">view_agenda</span>
                                <span class="text-xs font-medium">Alert Zone</span>
                            </div>
                            <div class="flex items-center gap-2 text-on-surface-variant">
                                <span class="material-symbols-outlined text-xs">visibility</span>
                                <span class="material-symbols-outlined text-xs">lock_open</span>
                            </div>
                        </div>
                        <div class="flex items-center justify-between p-2 rounded-lg hover:bg-surface-variant/10">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-xs">videocam</span>
                                <span class="text-xs font-medium text-on-surface-variant">Webcam Frame</span>
                            </div>
                            <div class="flex items-center gap-2 text-on-surface-variant">
                                <span class="material-symbols-outlined text-xs">visibility</span>
                                <span class="material-symbols-outlined text-xs">lock</span>
                            </div>
                        </div>
                        <div class="flex items-center justify-between p-2 rounded-lg hover:bg-surface-variant/10">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-xs">chat</span>
                                <span class="text-xs font-medium text-on-surface-variant">Chat Box</span>
                            </div>
                            <div class="flex items-center gap-2 text-on-surface-variant">
                                <span class="material-symbols-outlined text-xs">visibility</span>
                                <span class="material-symbols-outlined text-xs">lock_open</span>
                            </div>
                        </div>
                    </div>
                </section>
                
                <div class="h-px bg-outline-variant"></div>
                
                <!-- Asset Grid -->
                <section>
                    <label class="text-[10px] font-bold text-on-surface-variant uppercase mb-3 block">Quick Assets</label>
                    <div class="grid grid-cols-3 gap-2">
                        <div class="aspect-square glass-panel rounded-lg overflow-hidden border border-outline-variant group relative cursor-pointer">
                            <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAnCFNGxJ1RPkqB0ZR8hacUVKah1d1p5ZrAu_kttFKo0_YiHZvbr2kNVkuSYMjrub5-rHS_othUafZPlAGAQKJyT5U_nd_32qGP01GyMqopuD_WvFp9wH0sbLFPlRB3drUiFM6uQpXVxdUTKWq_0zjVrQ3LJHfp_l0kiZ6Q6HqD1FCPch6-bnccw7w8s0rRvHCIIw1Ihq9-Ok1NnOm7y41otEQKPsQ08q3PX9-Geh0k3QYepZcP4QEQKaYI_9IxCtNNPUSt8Wvm7LY"/>
                            <div class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        </div>
                        <div class="aspect-square glass-panel rounded-lg overflow-hidden border border-outline-variant group relative cursor-pointer">
                            <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDIdgX5eBnVSZjAnsSAIuaWW8igkch4WONxyIZ2JcO-DbelOk7MlKo861o0wdHXq3UniRWITpLXeqnANtC5tSn1oezjqXoxWKvMHjXxGRJB9ucZepju994UmoJNyIQylFH5K9GpoADMntz5o3iNL4_AhejABwhfPpx1gzsgHgv2xMFjPZU5bqNmiZDDHgVvPDMROjBWZGw75fZCM1N5sy-NYJnWBAju6Jo6dy-1eMH_u3OTIBRqorFcz1RM1Jy-48v9awXtCMLX4rE"/>
                        </div>
                        <div class="aspect-square glass-panel rounded-lg overflow-hidden border border-outline-variant group relative cursor-pointer">
                            <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBPK2aw2OoOVWJYBHo_Rkt_nZkd5Yyz_IUePQoH99cT4xhWAP_isX5CuZROvSjnJH35CQ7nAH1woyr-f-05p4ua0dwBtQXiJ0VrLmhZVcvRv_-X2j945cNA9NThrBUJbL3KkHild30SEutVoFONTlsv2awimfN6MYObEStAzGEml_yeGnRmIh9MaeadNDrlQze_maESWetCemUy3ohcPDwRUOYIvOmaHSJl5MkepV2zq5jklUuaEI0aba-UZwj4c0zQv60PpsKsTfE"/>
                        </div>
                        <div class="aspect-square glass-panel rounded-lg border-2 border-dashed border-outline-variant flex items-center justify-center hover:bg-surface-variant/20 transition-all cursor-pointer">
                            <span class="material-symbols-outlined text-on-surface-variant">upload</span>
                        </div>
                    </div>
                </section>
            </div>
            
            <!-- Panel Footer -->
            <div class="p-4 border-t border-outline-variant bg-surface-container-lowest">
                <button class="w-full py-2 bg-surface-variant/20 border border-outline-variant rounded-lg text-xs font-bold hover:bg-surface-variant/40 transition-all">Export Package</button>
            </div>
        </aside>
    </div>
    
    <script>
        // Generate timeline markers
        const markersContainer = document.getElementById('timeline-markers');
        if (markersContainer) {
            let html = '';
            for(let i=0; i<40; i++) {
                html += `<div class="w-12 h-4 shrink-0 border-l border-outline-variant/20 flex flex-col justify-end px-1"><span class="text-[8px] text-on-surface-variant/40">${i}s</span></div>`;
            }
            markersContainer.innerHTML = html;
        }

        // Canvas interactive states
        document.querySelectorAll('.canvas-item').forEach(el => {
            el.addEventListener('mouseenter', () => {
                el.style.backgroundColor = 'rgba(6, 182, 212, 0.1)';
                el.style.transform = 'scale(1.02)';
                el.style.transition = 'all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
            });
            el.addEventListener('mouseleave', () => {
                el.style.backgroundColor = 'rgba(6, 182, 212, 0.05)';
                el.style.transform = 'scale(1)';
            });
        });

        // Drafts selection logic
        const drafts = document.querySelectorAll('.draft-item');
        drafts.forEach(draft => {
            draft.addEventListener('click', () => {
                drafts.forEach(d => {
                    d.classList.remove('bg-primary-container/10', 'border-primary');
                    d.classList.add('glass-panel', 'border-transparent');
                    const label = d.querySelector('.label-text');
                    if(label) label.classList.remove('text-primary');
                    if(label) label.classList.add('text-on-surface');
                });
                draft.classList.add('bg-primary-container/10', 'border-primary');
                draft.classList.remove('glass-panel', 'border-transparent');
                const selectedLabel = draft.querySelector('.label-text');
                if (selectedLabel) selectedLabel.classList.add('text-primary');
            });
        });
    </script>
</body>
</html>
