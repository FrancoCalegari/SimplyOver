                    <span class="material-symbols-outlined text-sm text-on-surface-variant">zoom_in</span>
                    <span class="text-xs font-medium text-on-surface">65%</span>
                </div>
                <div class="flex items-center gap-2 px-2 border-r border-outline-variant">
                    <span class="material-symbols-outlined text-sm text-on-surface-variant">aspect_ratio</span>
                    <span class="text-xs font-medium text-on-surface">1920x1080</span>
                </div>
                <div class="flex items-center gap-3 px-2">
                    <button class="material-symbols-outlined text-[20px] text-secondary" style="font-variation-settings: 'FILL' 1;">grid_on</button>
                    <button class="material-symbols-outlined text-[20px] text-on-surface-variant">straighten</button>
                </div>
            </div>
            
            <!-- AI Assistant Button -->
            <button class="absolute bottom-28 right-6 flex items-center gap-2 px-4 py-2.5 bg-primary-container text-on-primary-container rounded-full text-xs font-bold violet-glow hover:scale-105 transition-all z-20">
                <span>AI Assist ✨</span>
            </button>
            
            <!-- Bottom Animation Timeline -->
            <div class="h-24 glass-panel border-t border-outline-variant flex flex-col z-30">
                <div class="flex items-center justify-between px-4 py-1 border-b border-outline-variant text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                    <div class="flex items-center gap-4">
                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[12px]">play_arrow</span> Timeline</span>
                        <span class="text-primary">00:02.15</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <span>Loop Enabled</span>
                        <span class="material-symbols-outlined text-[14px]">settings</span>
                    </div>
                </div>
                <div class="flex-1 flex timeline-scroll overflow-x-auto relative">
                    <!-- Timeline markers -->
                    <div class="flex divide-x divide-outline-variant/30 items-end pb-2" id="timeline-markers">
                        <!-- Markers will be generated by JS -->
                    </div>
                    <!-- Playhead -->
                    <div class="absolute left-64 top-0 bottom-0 w-px bg-primary z-10 pointer-events-none">
                        <div class="absolute -top-1 -left-1 w-2 h-2 bg-primary rounded-full"></div>
                    </div>
                    <!-- Keyframes -->
                    <div class="absolute top-4 left-24 w-4 h-4 rounded-sm bg-secondary rotate-45 border border-white/20 pointer-events-none"></div>
                    <div class="absolute top-4 left-96 w-4 h-4 rounded-sm bg-primary rotate-45 border border-white/20 pointer-events-none"></div>
                </div>
            </div>
