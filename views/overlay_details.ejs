    <script>
        const thumbnails = document.querySelectorAll('.aspect-video.rounded-lg.cursor-pointer');
        thumbnails.forEach(thumb => {
            thumb.addEventListener('click', () => {
                thumbnails.forEach(t => t.classList.remove('border-primary'));
                thumbnails.forEach(t => t.classList.add('border-white/10'));
                thumb.classList.remove('border-white/10');
                thumb.classList.add('border-primary');
            });
        });
    </script>
